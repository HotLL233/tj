classDiagram
    %% RBAC
    class User {
        +i64 id
        +String username
        +String password_hash
        +i64 role_id
        +i64 lab_id
        +bool must_change_password
    }
    class Role {
        +i64 id
        +String name
        +bool is_system
    }
    class RolePermission {
        +i64 id
        +i64 role_id
        +String permission
    }
    User "1" --> "1" Role : role_id
    Role "1" --> "*" RolePermission : 权限点

    %% 仪器
    class Instrument {
        +i64 id
        +String name
        +String status
        +String qr_code_path
    }
    class InstrumentBooking {
        +i64 id
        +i64 instrument_id
        +String status
    }
    class InstrumentMaintenance {
        +i64 id
        +i64 instrument_id
    }
    Instrument "1" --> "*" InstrumentBooking
    Instrument "1" --> "*" InstrumentMaintenance

    %% 库存
    class InventoryItem {
        +i64 id
        +String name
        +i64 category_id
    }
    class InventoryBatch {
        +i64 id
        +i64 item_id
        +f64 quantity
    }
    class InventoryTransaction {
        +i64 id
        +i64 item_id
        +String tx_type
    }
    InventoryItem "1" --> "*" InventoryBatch
    InventoryItem "1" --> "*" InventoryTransaction
    InventoryBatch "1" --> "0..*" InventoryTransaction : batch_id

    %% 采购
    class Supplier {
        +i64 id
        +String name
    }
    class PurchaseRequisition {
        +i64 id
        +String status
    }
    class PurchaseOrder {
        +i64 id
        +String order_no
        +i64 supplier_id
    }
    class PurchaseOrderItem {
        +i64 id
        +i64 order_id
    }
    Supplier "1" --> "*" PurchaseOrder
    PurchaseOrder "1" --> "*" PurchaseOrderItem
    PurchaseRequisition "0..*" ..> "0..1" PurchaseOrder : 转订单

    %% 审批
    class ApprovalRule {
        +i64 id
        +String biz_type
        +i64 priority
    }
    class ApprovalTask {
        +i64 id
        +String biz_type
        +String status
    }
    ApprovalRule "1" --> "*" ApprovalTask : 生成待办

    %% 通知 / 审计
    class Notification {
        +i64 id
        +String recipient
        +bool is_read
    }
    class AuditLog {
        +i64 id
        +String action
        +String module
        +String before_json
        +String after_json
    }

    note for AuditLog "WORM: 仅 INSERT，触发器禁止 UPDATE/DELETE"
    note for User "module 隔离: work/rd/instrument/inventory/purchase/approval"
