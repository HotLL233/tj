---
title: 录入流程
---
sequenceDiagram
    actor U as 用户
    participant HP as HomePage
    participant EP as EntryPage
    participant API as api/client.ts
    participant BE as FastAPI
    participant DB as SQLite

    U->>HP: 点击分组卡片
    HP->>EP: 路由跳转 /entry/:groupId
    EP->>API: GET /api/projects?group_id=X
    API->>BE: HTTP GET
    BE->>DB: SELECT * FROM projects WHERE group_id=X AND is_active=1
    DB-->>BE: 项目列表
    BE-->>API: {code:0, data:[...]}
    API-->>EP: 渲染项目列表

    U->>EP: 选择日期(可选)
    U->>EP: 在项目行输入数量, 点击提交
    EP->>API: POST /api/records {project_id, user_name, quantity, recorded_at}
    API->>BE: HTTP POST
    BE->>DB: INSERT INTO work_records (...)
    BE->>DB: INSERT INTO audit_log ('create', 'work_records', id, ...)
    DB-->>BE: OK
    BE-->>API: {code:0, data:{id:...}}
    API-->>EP: 提交成功提示
    EP->>EP: 清空该行输入框, 显示绿色对勾 2s

---
title: 统计查询流程
---
sequenceDiagram
    actor U as 用户
    participant SP as StatsPage
    participant API as api/client.ts
    participant BE as FastAPI
    participant DB as SQLite

    U->>SP: 进入统计页
    SP->>API: GET /api/stats/summary?group_by=week
    API->>BE: HTTP GET
    BE->>DB: SELECT strftime('%Y-%W', recorded_at) as week, SUM(quantity), COUNT(*)
    BE->>DB: FROM work_records WHERE deleted_at IS NULL GROUP BY week
    DB-->>BE: 汇总数据
    BE-->>API: {code:0, data:{total_quantity, details:[...]}}
    API-->>SP: 渲染统计卡片 + 表格

    U->>SP: 切换"按月" Tab
    SP->>API: GET /api/stats/summary?group_by=month
    API->>BE: HTTP GET
    BE->>DB: SELECT strftime('%Y-%m', recorded_at) as month, SUM(quantity), COUNT(*)
    DB-->>BE: 按月汇总
    BE-->>SP: 更新表格

    U->>SP: 切换"按用户" Tab
    SP->>API: GET /api/stats/by-user?start=&end=
    API->>BE: HTTP GET
    BE->>DB: SELECT user_name, SUM(quantity), COUNT(*) FROM work_records
    BE->>DB: WHERE deleted_at IS NULL GROUP BY user_name ORDER BY SUM(quantity) DESC
    DB-->>BE: 按用户汇总
    BE-->>SP: 渲染用户统计表

---
title: Excel导出流程
---
sequenceDiagram
    actor U as 用户
    participant SP as StatsPage
    participant API as api/client.ts
    participant BE as FastAPI
    participant DB as SQLite
    participant OX as openpyxl

    U->>SP: 点击「导出 Excel」
    SP->>U: 弹出确认（含时间范围提示）
    U->>SP: 确认导出
    SP->>API: GET /api/export/excel?start=&end=&group_id=
    API->>BE: HTTP GET (responseType: blob)
    BE->>DB: SELECT wr.*, p.name, pg.name FROM work_records wr
    BE->>DB: JOIN projects p ON wr.project_id=p.id
    BE->>DB: JOIN project_groups pg ON p.group_id=pg.id
    BE->>DB: WHERE wr.deleted_at IS NULL ORDER BY wr.recorded_at DESC
    DB-->>BE: 全量记录数据
    BE->>OX: 创建工作簿, 写入数据, 设置列宽
    OX-->>BE: xlsx 二进制
    BE-->>API: Content-Type: application/vnd.openxmlformats...
    API-->>SP: Blob 下载
    SP->>U: 浏览器触发下载

---
title: 项目分组管理流程
---
sequenceDiagram
    actor U as 用户
    participant MP as ManagePage
    participant API as api/client.ts
    participant BE as FastAPI
    participant DB as SQLite

    U->>MP: 进入管理页
    MP->>API: GET /api/groups
    API->>BE: HTTP GET
    BE->>DB: SELECT g.*, COUNT(p.id) as project_count
    BE->>DB: FROM project_groups g LEFT JOIN projects p ON g.id=p.group_id GROUP BY g.id
    DB-->>BE: 分组列表含项目数
    BE-->>MP: 渲染分组管理面板

    U->>MP: 创建新分组
    MP->>API: POST /api/groups {name:"新分组"}
    API->>BE: HTTP POST
    BE->>DB: INSERT INTO project_groups (name)
    DB-->>BE: OK
    BE-->>MP: 刷新列表

    U->>MP: 删除空分组
    MP->>API: DELETE /api/groups/{id}
    API->>BE: HTTP DELETE
    BE->>DB: SELECT COUNT(*) FROM projects WHERE group_id=?
    DB-->>BE: count=0 → 允许删除
    BE->>DB: DELETE FROM project_groups WHERE id=?
    DB-->>BE: OK
    BE-->>MP: 删除成功
